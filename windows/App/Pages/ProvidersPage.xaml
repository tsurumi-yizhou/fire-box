<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Pages.ProvidersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:App.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,12"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock
                x:Uid="ProvidersTitle"
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}" />
            <Button
                x:Uid="ProvidersAddApiKey"
                VerticalAlignment="Center"
                Click="AddApiKey_Click" />
            <Button
                x:Uid="ProvidersAddOAuth"
                VerticalAlignment="Center"
                Click="AddOAuth_Click" />
            <Button
                x:Uid="ProvidersAddLocal"
                VerticalAlignment="Center"
                Click="AddLocal_Click" />
            <ProgressRing
                Width="20"
                Height="20"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- Provider list -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Providers}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:ProviderDto">
                    <Grid Padding="0,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                x:Uid="ProvidersColumnName"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock
                                x:Uid="ProvidersColumnType"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind Type}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                x:Uid="ProvidersColumnBaseUrl"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind BaseUrl}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Button
                            x:Uid="ProvidersDelete"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Click="Delete_Click"
                            Tag="{x:Bind ProviderId}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
