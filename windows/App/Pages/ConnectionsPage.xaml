<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Pages.ConnectionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:App.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,12"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock
                x:Uid="ConnectionsTitle"
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}" />
            <Button
                x:Uid="ConnectionsRefresh"
                VerticalAlignment="Center"
                Click="Refresh_Click" />
            <ProgressRing
                Width="20"
                Height="20"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- List -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Connections}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:ConnectionDto">
                    <Grid Padding="0,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock
                                x:Uid="ConnectionsColumnClient"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind ClientName}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock
                                x:Uid="ConnectionsColumnRequests"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind RequestsCount}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                x:Uid="ConnectionsColumnAppPath"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind AppPath}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <StackPanel Grid.Column="3">
                            <TextBlock
                                x:Uid="ConnectionsColumnId"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind ConnectionId}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
