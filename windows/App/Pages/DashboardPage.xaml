<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="20">

            <!-- Status row -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    x:Uid="DashboardStatus"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold" />
                <TextBlock
                    VerticalAlignment="Center"
                    Text="{x:Bind ViewModel.Status, Mode=OneWay}" />
            </StackPanel>

            <!-- Row 1: request counters -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardTotalRequests"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.RequestsTotal, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardFailedRequests"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.RequestsFailed, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardPromptTokens"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.PromptTokens, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardCompletionTokens"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.CompletionTokens, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Row 2: cost / latency / connections -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardTotalCost"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.CostTotalFormatted, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardAvgLatency"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.LatencyAvgMs, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel>
                        <TextBlock
                            x:Uid="DashboardActiveConnections"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6" />
                        <TextBlock
                            Style="{ThemeResource TitleLargeTextBlockStyle}"
                            Text="{x:Bind ViewModel.ActiveConnections, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <!-- placeholder to keep grid balanced -->
                <Border Grid.Column="3" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
