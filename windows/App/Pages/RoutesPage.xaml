<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Pages.RoutesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:services="using:App.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,12"
            Orientation="Horizontal"
            Spacing="8">
            <TextBlock
                x:Uid="RoutesTitle"
                VerticalAlignment="Center"
                Style="{ThemeResource SubtitleTextBlockStyle}" />
            <Button
                x:Uid="RoutesAdd"
                VerticalAlignment="Center"
                Click="AddRoute_Click" />
            <Button
                x:Uid="RoutesRefresh"
                VerticalAlignment="Center"
                Click="Refresh_Click" />
            <ProgressRing
                Width="20"
                Height="20"
                VerticalAlignment="Center"
                IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
        </StackPanel>

        <!-- Route list -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Routes}"
            SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="services:RouteRuleDto">
                    <Grid Padding="0,8" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                x:Uid="RoutesColumnVirtualModelId"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind VirtualModelId}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock
                                x:Uid="RoutesColumnStrategy"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind Strategy}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                x:Uid="RoutesColumnDisplayName"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                Opacity="0.6" />
                            <TextBlock Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Button
                            x:Uid="RoutesDelete"
                            Grid.Column="3"
                            VerticalAlignment="Center"
                            Click="Delete_Click"
                            Tag="{x:Bind VirtualModelId}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
